@page "/"
@inject NavigationManager Nav
@inject AppState State

<h3>Local Secure Vault</h3>

<div class="card mb-3">
    <div class="card-body p-4">
        <p class="mb-4">Manage credentials in a local encrypted file.</p>

        <div class="d-flex flex-wrap gap-2">
            @if (ShowCreateButton)
            {
                <button class="btn btn-primary" @onclick="GoCreate">Create new vault</button>
            }
            <button class="btn btn-secondary" @onclick="GoOpen">Open existing vault</button>
            @if (State.IsUnlocked)
            {
                <button class="btn btn-outline-primary" @onclick="GoVault">Go to Vault</button>
            }
        </div>
    </div>
</div>

@code {
#if ANDROID
        private bool ShowCreateButton => false;
#else
        private bool ShowCreateButton => true;
#endif

        private void GoCreate() => Nav.NavigateTo("/create");
        private void GoVault() => Nav.NavigateTo("/vault");
        private void GoOpen() => Nav.NavigateTo("/open");
    }

@using Vault.Application.Abstractions;
@using Vault.Application.Services;
@using Vault.Application.Models;
@using Vault.App.Services;

@page "/open"
@inject NavigationManager Nav
@inject AppState State
@inject IVaultStore Store
@inject IVaultFilePicker Picker
@inject IRecentVaultPathStore Recent
@inject VaultAppService App
@inject IJSRuntime JS
@inject IBiometricAuthService BiometricAuth

<h3>Open existing vault</h3>

@if (State.IsUnlocked)
{
    <div class="alert alert-warning">
        <strong>The vault is currently unlocked.</strong>
        To open another vault, lock the current one first.
    </div>

    <div style="display:flex; gap:12px;" class="mb-3">
        <button class="btn btn-secondary" @onclick="BackToVault" disabled="@IsBusy">
            Back to vault
        </button>

        <button class="btn btn-danger" @onclick="LockAsync" disabled="@IsBusy">
            Lock vault
        </button>
    </div>

    <hr />
}

@if (HasRecent)
{
    <div class="mb-3">
        <button class="btn btn-outline-primary"
                @onclick="UseLastVault"
                disabled="@(IsBusy || State.IsUnlocked)">
            Open last vault
        </button>

        <div class="form-text">
            Last opened vault: <code>@RecentPathHint</code>
        </div>
    </div>
}

@if (ShowBiometricButton && !State.IsUnlocked)
{
    <div class="mb-3">
        <button class="btn btn-success"
                @onclick="UnlockWithBiometricAsync"
                disabled="@IsBusy">
                Unlock with fingerprint
        </button>
        <div class="form-text text-muted">
            Use your fingerprint to unlock the vault
        </div>
    </div>
}

<div class="mb-3">
    <label class="form-label">Vault file</label>

    <div style="display:flex; gap:12px;">
        <input class="form-control"
               @bind="VaultPath" @bind:event="oninput"
               @onkeypress="HandleKeyPress"
               disabled="@(IsBusy || State.IsUnlocked)" />

        <button class="btn btn-outline-secondary"
                @onclick="BrowseAsync"
                disabled="@(IsBusy || State.IsUnlocked)">
            Browse…
        </button>
    </div>
</div>

<div class="mb-3">
    <label class="form-label">Master password</label>
    <input type="password"
           class="form-control"
           @bind="Password" @bind:event="oninput"
           @onkeypress="HandleKeyPress"
           disabled="@(IsBusy || State.IsUnlocked)" />
</div>

<div style="display:flex; gap:12px;">
    <button class="btn btn-primary"
            @onclick="OpenAsync"
            disabled="@(IsBusy
                || State.IsUnlocked
                || string.IsNullOrWhiteSpace(VaultPath)
                || string.IsNullOrWhiteSpace(Password))">
        Open vault
    </button>

    <button class="btn btn-secondary" @onclick="Cancel" disabled="@IsBusy">
        Cancel
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(Error))
{
    <div class="alert alert-danger mt-3">@Error</div>
}

@code {
    private string VaultPath = "";
    private string Password = "";
    private string? Error;
    private bool IsBusy;
    private string? RecentPathHint;
    private bool HasRecent => !string.IsNullOrWhiteSpace(RecentPathHint);
    private bool ShowBiometricButton;
    private bool BiometricAvailable;

    protected override async Task OnInitializedAsync()
    {
        RecentPathHint = Recent.GetLastPath();
        BiometricAvailable = await BiometricAuth.IsBiometricAvailableAsync();

        // Check if there's a stored password for the recent vault
        if (BiometricAvailable && HasRecent)
        {
            ShowBiometricButton = await BiometricAuth.HasStoredPasswordAsync(RecentPathHint!);
        }
    }

    private void BackToVault() => Nav.NavigateTo("/vault");

    private async Task LockAsync()
    {
        Error = null;

        if (State.IsDirty)
        {
            var ok = await JS.InvokeAsync<bool>(
                "confirm",
                "You have unsaved changes. Lock anyway? (Changes will be lost)");
            if (!ok) return;
        }

        State.Lock();
        // replace:true avoid going back to a screen that no longer applies
        Nav.NavigateTo("/open", replace: true);
    }

    private async Task BrowseAsync()
    {
        Error = null;
        var picked = await Picker.PickVaultFileAsync();

        if (!string.IsNullOrWhiteSpace(picked))
            VaultPath = picked;
    }

    private async Task OpenAsync()
    {
        Error = null;
        IsBusy = true;

        try
        {
            var result = await App.OpenAsync(VaultPath, Password.AsMemory());

            if (!result.IsSuccess)
            {
                Error = result.Error!.UserMessage;

                // Only invalidates if the file does not exist or the path is invalid
                if (result.Error.Code is VaultErrorCode.FileNotFound or VaultErrorCode.InvalidFormat)
                    Recent.Clear();

                return;
            }

            var unlocked = result.Value!;
            State.SetUnlocked(unlocked.Path, unlocked.Document, unlocked.SessionKey, unlocked.Header);
            Recent.SetLastPath(unlocked.Path);

            // Offer to enable biometric authentication after successful unlock
            if (BiometricAvailable && !await BiometricAuth.HasStoredPasswordAsync(VaultPath))
            {
                var enableBiometric = await JS.InvokeAsync<bool>(
                    "confirm",
                    "Do you want to enable fingerprint unlock for this vault?");

                if (enableBiometric)
                {
                    await BiometricAuth.StorePasswordAsync(VaultPath, Password);
                }
            }

            Nav.NavigateTo("/vault");
        }
        finally
        {
            IsBusy = false;
            Password = "";
        }
    }

    private async Task UnlockWithBiometricAsync()
    {
        if (string.IsNullOrWhiteSpace(RecentPathHint))
            return;

        Error = null;
        IsBusy = true;

        try
        {
            var authenticated = await BiometricAuth.AuthenticateAsync("Unlock vault");

            if (!authenticated)
            {
                Error = "Biometric authentication cancelled or failed";
                return;
            }

            var storedPassword = await BiometricAuth.GetPasswordAsync(RecentPathHint);

            if (string.IsNullOrEmpty(storedPassword))
            {
                Error = "Could not retrieve stored password for biometric unlock";
                ShowBiometricButton = false;
                return;
            }

            VaultPath = RecentPathHint;
            var result = await App.OpenAsync(VaultPath, storedPassword.AsMemory());

            if (!result.IsSuccess)
            {
                Error = result.Error!.UserMessage;

                // If password is wrong, clear stored biometric data
                if (result.Error.Code == VaultErrorCode.AuthenticationDecryptionError)
                {
                    await BiometricAuth.ClearStoredPasswordAsync(VaultPath);
                    ShowBiometricButton = false;
                    Error += " (Stored password removed. Please enter the password manually.)";
                }

                return;
            }

            var unlocked = result.Value!;
            State.SetUnlocked(unlocked.Path, unlocked.Document, unlocked.SessionKey, unlocked.Header);
            Recent.SetLastPath(unlocked.Path);
            Nav.NavigateTo("/vault");
        }
        catch (Exception ex)
        {
            Error = $"Error during biometric authentication: {ex.Message}";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private void UseLastVault()
    {
        if (!string.IsNullOrWhiteSpace(RecentPathHint))
        {
            VaultPath = RecentPathHint;
            Error = null;
        }
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter"
            && !IsBusy
            && !State.IsUnlocked
            && !string.IsNullOrWhiteSpace(VaultPath)
            && !string.IsNullOrWhiteSpace(Password))
        {
            await OpenAsync();
        }
    }

    private void Cancel() => Nav.NavigateTo("/");
}

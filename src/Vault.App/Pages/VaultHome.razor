@using Vault.Application.Services;
@using Vault.App.Services;

@page "/vault"
@inject AppState State
@inject NavigationManager Nav
@inject VaultAppService App
@inject SearchService SearchService
@inject IVaultExportPicker ExportPicker

@inject ClipboardService Clipboard

@* HEADER - Title and global actions *@
<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
    <h3 class="mb-0">Vault</h3>
    
    @if (State.UnlockedDocument is not null)
    {
        <div class="d-flex flex-wrap gap-2">
            <button class="btn btn-success" @onclick="SaveAsync" disabled="@(!State.IsDirty || IsBusy)">Save</button>
            @if (ShowExportButton)
            {
                <button class="btn btn-outline-primary" @onclick="ExportAsync" disabled="@IsBusy">Export</button>
            }
            <button class="btn btn-outline-danger" @onclick="LockVault">Lock</button>
        </div>
    }
</div>

@if (State.UnlockedDocument is null)
{
    <div class="alert alert-warning">
        Vault is locked. <a href="/open">Open a vault</a>.
    </div>
    return;
}

@if (!string.IsNullOrWhiteSpace(SaveMsg))
{
    <div class="alert alert-success">@SaveMsg</div>
}

@* CONTROLS - Search and entry actions *@
<div class="card mb-3">
    <div class="card-body py-3">
        <div class="d-flex flex-column flex-lg-row gap-2 align-items-start align-items-lg-center vault-toolbar">
            <input class="form-control vault-search-input" placeholder="Search entries..."
                   @bind="Search" @bind:event="oninput" />
            
            <div class="d-flex gap-2 vault-toolbar-actions ms-lg-auto justify-content-end">
                <button class="btn btn-primary vault-add-entry-btn" @onclick="NewEntry">Add Entry</button>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Error))
{
    <div class="alert alert-danger">@Error</div>
}

@* ENTRIES LIST - Card format *@
@if (EntriesFiltered.Count == 0)
{
    <div class="text-muted">No entries.</div>
}
else
{
    <div class="d-flex flex-column gap-2" style="max-width: 100%; overflow-x: hidden;">
        @foreach (var e in EntriesFiltered)
        {
            <div class="card">
                <div class="card-body py-3" style="display: flex; flex-direction: column;">
                    @* First row: Name + Tags *@
                    <div class="d-flex justify-content-between align-items-start mb-2 gap-2 flex-wrap" style="flex-shrink: 0;">
                        <div class="fw-bold fs-5" style="flex: 1 1 auto; min-width: 0; overflow-wrap: break-word;">@e.Name</div>
                        
                        @if (e.Tags.Count > 0)
                        {
                            <div class="d-flex flex-wrap gap-2 justify-content-end" style="flex: 0 1 auto;">
                                @foreach (var tag in e.Tags)
                                {
                                    <span class="badge bg-secondary">@tag</span>
                                }
                            </div>
                        }
                    </div>
                    
                    @* Username and Notes *@
                    <div style="flex: 1; min-width: 0; overflow-x: hidden;">
                        @if (!string.IsNullOrWhiteSpace(e.Username))
                        {
                            <div class="text-muted mb-2" style="overflow-wrap: break-word;">@e.Username</div>
                        }
                        
                        @if (!string.IsNullOrWhiteSpace(e.Notes))
                        {
                            <div class="text-muted small mb-2" style="overflow-wrap: break-word;">
                                <span class="fw-bold">Notes:</span> @e.Notes
                            </div>
                        }
                    </div>
                    
                    @* Action buttons - always at the end *@
                    <div class="d-flex gap-2 justify-content-end" style="flex-shrink: 0;">
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => CopyPasswordAsync(e.Id)">
                            @(CopiedId == e.Id ? "Copied" : "Copy")
                        </button>
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => EditEntry(e.Id)">Edit</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => ConfirmDelete(e.Id)">Delete</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (EditorOpen)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@EditorTitle</h5>
                    <button type="button" class="btn-close" @onclick="CloseEditor"></button>
                </div>
                <div class="modal-body">
                    <EntryEditor Model="EditorModel"
                                 AvailableTags="AllAvailableTags"
                                 OnCancel="CloseEditor"
                                 OnSave="SaveEditor" />
                </div>
            </div>
        </div>
    </div>
}

@if (DeleteOpen)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Delete entry</h5>
                    <button type="button" class="btn-close" @onclick="CloseDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete <strong>@DeleteName</strong>?</p>
                    <p class="text-muted small mb-0">This only removes it from memory. Use Save to persist.</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseDelete">Cancel</button>
                    <button class="btn btn-danger" @onclick="DeleteNow">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool ShowExportButton => OperatingSystem.IsAndroid();

    private string? Error;
    private string Search = "";

    private bool EditorOpen;
    private Guid? EditingId;
    private EntryEditorModel EditorModel = new();
    private string EditorTitle => EditingId is null ? "Add entry" : "Edit entry";

    private bool DeleteOpen;
    private Guid DeleteId;
    private string DeleteName = "";
    private bool IsBusy;
    private string? SaveMsg;
    private Guid? CopiedId;
    private CancellationTokenSource? _copyCts;

    private IReadOnlyList<Vault.Domain.VaultEntry> EntriesFiltered =>
        SearchService.Search(State.UnlockedDocument!, new SearchQuery(Search));
    
    private IReadOnlyList<string> AllAvailableTags
    {
        get
        {
            if (State.UnlockedDocument is null) return Array.Empty<string>();
            
            return State.UnlockedDocument.Entries
                .SelectMany(e => e.Tags)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(t => t, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
    }
    
    private void NewEntry()
    {
        Error = null;
        EditingId = null;
        EditorModel = EntryEditorModel.FromEntry(null);
        EditorOpen = true;
    }

    private void EditEntry(Guid id)
    {
        Error = null;
        var e = State.UnlockedDocument!.GetEntry(id);
        EditingId = id;
        EditorModel = EntryEditorModel.FromEntry(e);
        EditorOpen = true;
    }

    private void CloseEditor()
    {
        EditorOpen = false;
        EditingId = null;
    }

    private void SaveEditor()
    {
        Error = null;

        try
        {
            if (EditingId is null)
            {
                var entry = EditorModel.ToNewEntry();
                var res = App.AddEntry(State.UnlockedDocument!, entry);
                if (!res.IsSuccess) { Error = res.Error!.UserMessage; return; }
            }
            else
            {
                var data = EditorModel.ToUpdateData();
                var res = App.UpdateEntry(
                    State.UnlockedDocument!,
                    EditingId.Value,
                    data.Name,
                    data.Password,
                    data.Username,
                    data.Url,
                    data.Notes,
                    data.Tags);

                if (!res.IsSuccess) { Error = res.Error!.UserMessage; return; }
            }
            State.MarkDirty();
            CloseEditor();
        }
        catch (Exception ex)
        {
            Error = ex.Message;
        }
    }

    private void ConfirmDelete(Guid id)
    {
        Error = null;
        var e = State.UnlockedDocument!.GetEntry(id);
        DeleteId = id;
        DeleteName = e.Name;
        DeleteOpen = true;
    }

    private void CloseDelete()
    {
        DeleteOpen = false;
        DeleteId = Guid.Empty;
        DeleteName = "";
    }

    private void DeleteNow()
    {
        Error = null;
        var res = App.DeleteEntry(State.UnlockedDocument!, DeleteId);
        if (!res.IsSuccess) { Error = res.Error!.UserMessage; return; }

        State.MarkDirty();
        CloseDelete();
    }

    private void LockVault()
    {
        if (State.IsDirty)
        {
            Error = "You have unsaved changes. Save before locking.";
            return;
        }

        State.Lock();
        Nav.NavigateTo("/");
    }

    private async Task SaveAsync()
    {
        SaveMsg = null;
        Error = null;
        IsBusy = true;

        try
        {
            var res = await App.SaveAsync(
                State.CurrentVaultPath!,
                State.UnlockedDocument!,
                State.SessionKey!,
                State.CurrentHeader!);

            if (!res.IsSuccess)
            {
                Error = res.Error!.UserMessage;
                return;
            }

            State.MarkSaved();
            SaveMsg = "Saved successfully.";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task ExportAsync()
    {
        SaveMsg = null;
        Error = null;

        if (State.UnlockedDocument is null || State.SessionKey is null || State.CurrentHeader is null)
        {
            Error = "No unlocked vault to export.";
            return;
        }

        IsBusy = true;
        try
        {
            var suggestedName = BuildSuggestedExportName();
            var destination = await ExportPicker.PickExportDestinationAsync(suggestedName);
            if (string.IsNullOrWhiteSpace(destination))
                return;

            var res = await App.SaveAsync(
                destination,
                State.UnlockedDocument,
                State.SessionKey,
                State.CurrentHeader);

            if (!res.IsSuccess)
            {
                Error = res.Error!.UserMessage;
                return;
            }

            SaveMsg = "Export completed.";
        }
        finally
        {
            IsBusy = false;
        }
    }

    private string BuildSuggestedExportName()
    {
        var name = State.UnlockedDocument?.Meta.VaultName;
        if (string.IsNullOrWhiteSpace(name))
            return "vault-export.vlt";

        foreach (var c in Path.GetInvalidFileNameChars())
            name = name.Replace(c, '_');

        name = name.Trim();
        if (!name.EndsWith(".vlt", StringComparison.OrdinalIgnoreCase))
            name += ".vlt";

        return string.IsNullOrWhiteSpace(name) ? "vault-export.vlt" : name;
    }

    private async Task CopyPasswordAsync(Guid id)
    {
        Error = null;

        var e = State.UnlockedDocument!.GetEntry(id);

        await Clipboard.SetTextAsync(e.Password);

        CopiedId = id;

        _copyCts?.Cancel();
        _copyCts = new CancellationTokenSource();

        try
        {
            await Task.Delay(1200, _copyCts.Token);
            if (CopiedId == id) CopiedId = null;
        }
        catch (TaskCanceledException) { }
    }
}
